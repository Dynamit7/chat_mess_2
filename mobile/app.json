{
  "expo": {
    "name": "Talkify",
    "slug": "nexus-messenger",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "nexus",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0b0a16",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.xusan.nexusmessenger"
    },
    "android": {
      "package": "com.xusan.nexusmessenger",
      "adaptiveIcon": {
        "backgroundColor": "#060814",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "owner": "husan1707",
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      "expo-video",
      "expo-notifications",
      [
        "expo-image-picker",
        {
          "photosPermission": "Talkify needs access to your photos so you can share images in chats.",
          "cameraPermission": "Talkify needs access to your camera so you can capture and share moments."
        }
      ],
      "expo-splash-screen",
      [
        "expo-audio",
        {
          "microphonePermission": "Talkify needs access to your microphone so you can record voice messages."
        }
      ],
      "expo-sqlite",
      [
        "@config-plugins/react-native-webrtc",
        {
          "cameraPermission": "Talkify needs access to your camera for video calls.",
          "microphonePermission": "Talkify needs access to your microphone for calls."
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "30da4392-ef02-448b-8543-aab112e4a592"
      }
    }
  }
}
