+package expo.modules.interfaces.barcodescanner
+
+data class BarCodeScannerResult(
+    val type: Int,
+    val value: String?,
+    val raw: String?,
+    var cornerPoints: MutableList<Int>,
+    var referenceImageHeight: Int,
+    var referenceImageWidth: Int
+) {
+    val boundingBox: BoundingBox
+        get() {
+            if (cornerPoints.isEmpty()) {
+                return BoundingBox(0, 0, 0, 0)
+            }
+            var minX = cornerPoints[0]
+            var minY = cornerPoints[1]
+            var maxX = cornerPoints[0]
+            var maxY = cornerPoints[1]
+
+            for (i in cornerPoints.indices step 2) {
+                val x = cornerPoints[i]
+                val y = cornerPoints[i + 1]
+                minX = minOf(minX, x)
+                minY = minOf(minY, y)
+                maxX = maxOf(maxX, x)
+                maxY = maxOf(maxY, y)
+            }
+
+            return BoundingBox(minX, minY, maxX - minX, maxY - minY)
+        }
+
+    data class BoundingBox(
+        val x: Int,
+        val y: Int,
+        val width: Int,
+        val height: Int
+    )
+}
